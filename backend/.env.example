# ================================================================
# CORNERSTONE SCHOOLS — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env to version control.
# ================================================================

# ── Server ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5500

# ── Database ────────────────────────────────────────────────────
DB_PATH=./data/cornerstone.db

# ── JWT ─────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_hex_secret
JWT_EXPIRES_IN=7d

# ── Email (Nodemailer) ───────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=Cornerstone Schools <no-reply@cornerstoneschools.ug>
ADMIN_EMAIL=admin@cornerstoneschools.ug
ADMISSIONS_EMAIL=admissions@cornerstoneschools.ug

# ── Flutterwave ──────────────────────────────────────────────────
# Get keys from https://dashboard.flutterwave.com
FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLW_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FLW_WEBHOOK_HASH=your_flutterwave_webhook_secret_hash

# Donation redirect URLs (after payment)
DONATION_SUCCESS_URL=http://localhost:5500/donate.html?status=success
DONATION_CANCEL_URL=http://localhost:5500/donate.html?status=cancelled

# ── Africa's Talking (SMS) ───────────────────────────────────────
# Get from https://account.africastalking.com
AT_USERNAME=sandbox
AT_API_KEY=your_africastalking_api_key
# In sandbox, use username=sandbox and AT_API_KEY from your sandbox app

# ── Rate Limiting ────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
CONTACT_RATE_LIMIT_MAX=10
DONATE_RATE_LIMIT_MAX=20
